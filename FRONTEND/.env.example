# ==========================================
# ShopSphere Frontend Environment Variables
# ==========================================

# API Configuration
# The base URL for the backend API
VITE_API_BASE_URL=http://localhost:3000

# Cloudinary Configuration (Required for image uploads)
# Get these from your Cloudinary Dashboard: https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# NOTE: For Cloudinary uploads to work:
# 1. Create an unsigned upload preset in your Cloudinary dashboard
# 2. Set the preset name here
# 3. The upload preset should be configured for "unsigned" uploads

# Optional: Analytics/Monitoring (if used)
# VITE_GOOGLE_ANALYTICS_ID=
